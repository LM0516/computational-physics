\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{preamble}[2024/02/17 Custom Preamble for Computational Physics Report]

% -------------------------------------------------------------------
%  Packages
% -------------------------------------------------------------------
\RequirePackage[a4paper, margin=2.5cm]{geometry} % Better margins
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{microtype}      % Improved typography

% Load ams BEFORE newpx to avoid \Bbbk and \openbox conflicts
\RequirePackage{amsmath, amssymb}

% Suppress \openbox before loading amsthm (newpxmath defines it first)
\let\openbox\relax
\RequirePackage{amsthm}

\RequirePackage{newpxtext, newpxmath} % Palatino font (text & math)

\RequirePackage{xcolor}          % Colors
\RequirePackage{graphicx}
\RequirePackage{booktabs}        % Better tables
\RequirePackage{enumitem}        % Custom lists
\RequirePackage{listings}        % Code blocks
\RequirePackage{caption}         % Caption styling
\RequirePackage{fancyhdr}        % Headers & Footers
\RequirePackage{thmtools}
\RequirePackage[many]{tcolorbox} % Colorful boxes
\RequirePackage{hyperref}        % Hyperlinks (load last)

% -------------------------------------------------------------------
%  Colors
% -------------------------------------------------------------------
\definecolor{codegreen}{rgb}{0,0.6,0}
\definecolor{codegray}{rgb}{0.5,0.5,0.5}
\definecolor{codepurple}{rgb}{0.58,0,0.82}
\definecolor{backcolour}{rgb}{0.95,0.95,0.92}
\definecolor{linkcolor}{rgb}{0.0, 0.2, 0.6}
\definecolor{accentcolor}{RGB}{41, 128, 185} % Nice blue
\definecolor{framecolor}{RGB}{0, 0, 0}

% -------------------------------------------------------------------
%  Hyperref Setup
% -------------------------------------------------------------------
\hypersetup{
    colorlinks=true,
    linkcolor=accentcolor,
    filecolor=magenta,
    urlcolor=cyan,
    pdftitle={Computational Physics Report},
    pdfpagemode=FullScreen,
}
\urlstyle{same}

% -------------------------------------------------------------------
%  Header & Footer
% -------------------------------------------------------------------
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\slshape \rightmark}
\fancyhead[R]{\slshape \leftmark}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0.4pt}

% -------------------------------------------------------------------
%  Code Listings Setup
% -------------------------------------------------------------------
\lstdefinelanguage{Julia}{
  morekeywords={abstract,break,case,catch,const,continue,do,else,elseif,
    end,export,false,for,function,global,if,import,importall,let,local,
    macro,module,quote,return,true,try,type,typealias,using,while},
  sensitive=true,
  alsoother={$},
  morecomment=[l]\#,
  morecomment=[n]{\#=}{=\#},
  morestring=[s]{"}{"},
  morestring=[m]{'}{'},
}[keywords,comments,strings]

\lstdefinestyle{mystyle}{
    backgroundcolor=\color{backcolour},
    commentstyle=\color{codegreen},
    keywordstyle=\color{magenta},
    numberstyle=\tiny\color{codegray},
    stringstyle=\color{codepurple},
    basicstyle=\ttfamily\small,
    breakatwhitespace=false,
    breaklines=true,
    captionpos=b,
    keepspaces=true,
    numbers=left,
    numbersep=5pt,
    showspaces=false,
    showstringspaces=false,
    showtabs=false,
    tabsize=2,
    frame=single,
    rulecolor=\color{codegray}
}

\lstset{style=mystyle}

% -------------------------------------------------------------------
%  Theorems & Environments
% -------------------------------------------------------------------

\declaretheorem[
  name={Theorem},
  numberwithin=section,
  refname={theorem,theorems},
  Refname={Theorem,Theorems}
]{theorem}

% Suppress amsthm's \proof before redefining it with thmtools
\let\proof\relax
\let\endproof\relax

\declaretheorem[
  parent=theorem,
  style=remark,
  name={Proof},
  numbered=yes
]{proof}

\declaretheorem[
  name={Corollary},
  numberlike=theorem,
  refname={corollary},
  Refname={Corollary}
]{corollary}

\declaretheorem[
  style=definition,
  name={Definition},
  numberlike=theorem,
  refname={definition,definitions},
  Refname={Definition,Definitions}
]{definition}

\declaretheorem[
  style=definition,
  name={Observation},
  numberlike=theorem,
  refname={observation,observations},
  Refname={Observation,Observations}
]{observation}

\declaretheorem[
  style=definition,
  name={Example},
  numberlike=theorem,
  refname={example,examples},
  Refname={Example,Examples}
]{example}

\declaretheorem[
  style=definition,
  name={Exercise},
  numberlike=theorem,
  refname={esercizio,esercizi},
  Refname={Esercizio,Esercizi}
]{exercise}

\declaretheorem[
  parent=exercise,
  style=remark,
  name={Solution},
  numbered=yes
]{solution}

\declaretheorem[
  style=remark,
  name={Remark},
  numberlike=theorem,
  refname={nota,note},
  Refname={Nota,Note}
]{note}

% -------------------------------------------------------------------
%  Visual Styling (Boxing)
% -------------------------------------------------------------------

% Style for Exercise: Blue Box
\tcolorboxenvironment{exercise}{
  enhanced,
  colback=accentcolor!5!white,
  colframe=accentcolor,
  arc=0pt, outer arc=0pt,
  boxrule=1pt,
  left=2mm, right=2mm, top=2mm, bottom=2mm,
  before skip=10pt, after skip=10pt,
  breakable
}

\tcolorboxenvironment{solution}{
  enhanced,
  colback=gray!5!white,
  colframe=gray!50!black,
  boxrule=0.5pt,
  arc=0pt, outer arc=0pt,
  left=2mm, right=2mm, top=2mm, bottom=2mm,
  before skip=10pt, after skip=10pt,
  breakable,
  title={Solution},
  coltitle=black,
  fonttitle=\bfseries\small,
  attach boxed title to top left={yshift=-2mm, xshift=2mm},
  boxed title style={colback=gray!10!white, boxrule=0pt, frame hidden}
}

\tcolorboxenvironment{example}{
  enhanced,
  colback=orange!5!white,
  colframe=orange!80!black,
  boxrule=0.5pt,
  arc=0pt, outer arc=0pt,
  left=2mm, right=2mm, top=2mm, bottom=2mm,
  before skip=10pt, after skip=10pt,
  breakable
}
